<Window x:Class="COM3D2_DLC_Batcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:COM3D2_DLC_Batcher.ViewModels"
        mc:Ignorable="d"
        Title="COM3D2 DLC Batcher" Height="920" Width="740"
        Background="#1E1E2E" Foreground="#CDD6F4"
        FontFamily="Consolas" FontSize="13"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#a6adc8"/>
            <Setter Property="Foreground" Value="#A6E3A1"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    
    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Game Version -->
        <GroupBox Header="Game Version" Grid.Row="0" Margin="0,0,0,10" Foreground="#BAC2DE" BorderBrush="#45475A">
            <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Content="{Binding DisplayName}" GroupName="GameVersion"
                                     IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                     Margin="10,5" Foreground="#CDD6F4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Source Path -->
        <GroupBox Header="1. SOURCE (folder containing DLCs to install)" Grid.Row="1" Margin="0,5" Foreground="#F9E2AF" BorderBrush="#45475A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="5" AllowDrop="True" Drop="Path_Drop"/>
                <Button Content="Browse..." Command="{Binding BrowseSrcCommand}" Grid.Column="1" Margin="5,5,10,5" Padding="10,2"/>
            </Grid>
        </GroupBox>

        <!-- Destination Path -->
        <GroupBox Header="2. DESTINATION (game 'dlc' folder)" Grid.Row="2" Margin="0,5" Foreground="#89B4FA" BorderBrush="#45475A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding DestPath, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="5" AllowDrop="True" Drop="Path_Drop"/>
                <Button Content="Browse..." Command="{Binding BrowseDstCommand}" Grid.Column="1" Margin="5,5,10,5" Padding="10,2"/>
            </Grid>
        </GroupBox>

        <!-- Stats Panel -->
        <Border Grid.Row="3" Margin="0,10" Background="#313244" CornerRadius="3">
            <TextBlock Text="{Binding StatsText}" Margin="10,8" Foreground="#CDD6F4"/>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="4" Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal">
                <Button Content="1. Scan" Command="{Binding ScanCommand}" Margin="0,0,5,0" Padding="15,10" FontWeight="Bold"/>
                <Button Content="2. Extract &amp; Copy" Command="{Binding ExtractCommand}" Margin="0,0,5,0" Padding="15,10" FontWeight="Bold"/>
                <Button Content="3. Process DLCs" Command="{Binding ProcessCommand}" Margin="0,0,5,0" Padding="15,10" FontWeight="Bold"/>
                <Button Content="Run All" Command="{Binding RunAllCommand}" Margin="20,0,5,0" Padding="15,10"/>
            </StackPanel>

            <Button Content="Cancel" Command="{Binding CancelCommand}" Grid.Column="1" Padding="15,10" Background="#F38BA8" Foreground="#11111B"/>
        </Grid>

        <!-- Log -->
        <ScrollViewer Grid.Row="5" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Background="#181825" Padding="5">
            <ItemsControl ItemsSource="{Binding LogEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Progress Bar -->
        <Grid Grid.Row="6" Margin="0,10,0,0">
            <ProgressBar Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}" Height="18"/>
            <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1E1E2E" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>
